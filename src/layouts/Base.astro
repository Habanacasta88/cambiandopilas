---
import '../styles/global.css';
import '@fontsource-variable/inter';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  schema?: object | object[];
  noindex?: boolean;
  ogType?: string;
  prevUrl?: string;
  nextUrl?: string;
}

const {
  title,
  description = 'Guías y tutoriales sobre cómo cambiar pilas y baterías de llaves de coche, auriculares, relojes y dispositivos electrónicos.',
  ogImage,
  canonicalUrl,
  schema,
  noindex = false,
  ogType = 'website',
  prevUrl,
  nextUrl,
} = Astro.props;

const siteUrl = 'https://cambiandopilas.com';
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : siteUrl + ogImage)
  : siteUrl + '/og-default.svg';
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  {prevUrl && <link rel="prev" href={siteUrl + prevUrl} />}
  {nextUrl && <link rel="next" href={siteUrl + nextUrl} />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content="Cambiando de Pilas" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:image" content={resolvedOgImage} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts: auto-hosted, zero external requests -->

  <!-- Schema.org -->
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-logo">
        <span>Cambiando de Pilas</span>
      </a>

      <button class="nav-toggle" aria-label="Abrir menú" id="navToggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>

      <nav class="main-nav" id="mainNav">
        <a href="/">Inicio</a>
        <a href="/categoria/blog">Llaves de coche</a>
        <a href="/categoria/audi">Audi</a>
        <a href="/categoria/renault">Renault</a>
        <a href="/categoria/volkswagen">Volkswagen</a>
        <a href="/categoria/mercedes-benz">Mercedes</a>
        <a href="/categoria/digital">Digital</a>
        <a href="/categoria/reloj">Reloj</a>
        <a href="/tipos-de-pilas">🔋 Guía</a>
        <a href="/blog">Blog</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Categorías</h4>
          <a href="/categoria/blog">Llaves de coche</a>
          <a href="/categoria/audi">Audi</a>
          <a href="/categoria/renault">Renault</a>
          <a href="/categoria/volkswagen">Volkswagen</a>
          <a href="/categoria/mercedes-benz">Mercedes Benz</a>
          <a href="/categoria/digital">Digital</a>
          <a href="/categoria/reloj">Reloj</a>
        </div>
        <div class="footer-col">
          <h4>Guías</h4>
          <a href="/tipos-de-pilas">Tipos de pilas para llaves</a>
          <a href="/blog">Todos los artículos</a>
        </div>
        <div class="footer-col">
          <h4>Sitio</h4>
          <a href="/sobre-nosotros">Sobre nosotros</a>
          <a href="/politica-de-privacidad">Política de privacidad</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} cambiandopilas.com — Guías para cambiar pilas y baterías.</p>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('mainNav')?.classList.toggle('active');
    });
  </script>
</body>
</html>
