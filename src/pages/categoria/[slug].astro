---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { generateExcerpt, cleanWpContent } from '../../utils/content';
import postsData from '../../data/posts.json';

const categoryMap: Record<string, string> = {
  'blog': 'Blog',
  'audi': 'Audi',
  'renault': 'Renault',
  'volkswagen': 'Volkswagen',
  'mercedes-benz': 'Mercedes benz',
  'digital': 'Digital',
  'reloj': 'Reloj',
};

const categoryLabels: Record<string, string> = {
  'blog': 'Llaves de coche',
  'audi': 'Audi',
  'renault': 'Renault',
  'volkswagen': 'Volkswagen',
  'mercedes-benz': 'Mercedes Benz',
  'digital': 'Digital',
  'reloj': 'Reloj',
};

export function getStaticPaths() {
  return [
    { params: { slug: 'blog' } },
    { params: { slug: 'audi' } },
    { params: { slug: 'renault' } },
    { params: { slug: 'volkswagen' } },
    { params: { slug: 'mercedes-benz' } },
    { params: { slug: 'digital' } },
    { params: { slug: 'reloj' } },
  ];
}

const { slug } = Astro.params;
const catName = categoryMap[slug!] || slug;
const catLabel = categoryLabels[slug!] || slug;

const filteredPosts = postsData.filter((post: any) =>
  post.categories && post.categories.includes(catName)
);
---

<Base
  title={`${catLabel} - Cambiando de Pilas`}
  description={`Guías sobre cómo cambiar la pila y batería en ${catLabel.toLowerCase()}. ${filteredPosts.length} artículos disponibles.`}
>
  <div class="container">
    <Breadcrumbs items={[
      { name: 'Categorías', url: '/' },
      { name: catLabel, url: `/categoria/${slug}` },
    ]} />

    <header class="article-header">
      <h1>{catLabel}</h1>
      <p style="color:#666">{filteredPosts.length} artículos en esta categoría</p>
    </header>

    <div class="card-grid">
      {filteredPosts.map((post: any) => (
        <ArticleCard
          title={post.title}
          slug={post.slug}
          excerpt={post.seoDescription || post.excerpt || generateExcerpt(cleanWpContent(post.body || ''), 120)}
          featuredImage={post.featuredImage}
          date={post.date}
        />
      ))}
    </div>
  </div>
</Base>
