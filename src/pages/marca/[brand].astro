<Base
  title={`Cambiar pila llave ${def.name} - Guías por modelo | Cambiando de Pilas`}
  description={`Guías para cambiar la pila de la llave de ${def.name}. Tabla de pilas por modelo (${def.pila} y más). Tutoriales paso a paso para todos los modelos.`}
  schema={[breadcrumb, faqSchema]}
  ogType="website"
>
  <div class="container">
    <Breadcrumbs items={[
      { name: 'Marcas', url: '/marca/' + brand },
      { name: def.name, url: '/marca/' + brand },
    ]} />

    <header class="article-header">
      <h1>Cambiar pila llave {def.name}</h1>
      <p style="color:#666">Guías por modelo · Pila habitual: <strong>{def.pila}</strong></p>
    </header>

    <div class="brand-intro" set:html={def.intro} />

    <!-- Model table -->
    <section class="brand-table-section">
      <h2>Tabla de pilas por modelo {def.name}</h2>
      <div class="table-wrapper">
        <table class="brand-table">
          <thead>
            <tr>
              <th>Modelo</th>
              <th>Pila</th>
              <th>Notas</th>
            </tr>
          </thead>
          <tbody>
            {def.modelos.map((row) => (
              <tr>
                <td>{row.modelo}</td>
                <td><a href={`/tipos-de-pilas/#${row.pila.toLowerCase()}`} class="pill-link">{row.pila}</a></td>
                <td style="color:#777;font-size:.85rem">{row.nota || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Articles -->
    {brandPosts.length > 0 && (
      <section>
        <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:1.5rem">
          Guías de cambio de pila para {def.name}
        </h2>
        <div class="card-grid">
          {brandPosts.map((post: any) => (
            <ArticleCard
              title={post.title}
              slug={post.slug}
              excerpt={post.seoDescription || post.excerpt || generateExcerpt(cleanWpContent(post.body || ''), 120)}
              featuredImage={post.featuredImage}
              date={post.date}
            />
          ))}
        </div>
        <div style="margin-top:1.5rem;text-align:center">
          <a href={`/categoria/${def.catSlug}`} class="cta-button">
            Ver todos los artículos de {def.name} →
          </a>
        </div>
      </section>
    )}

    <!-- FAQ -->
    <section class="faq-section" style="margin-top:3rem" aria-label="Preguntas frecuentes">
      <h2 class="faq-heading">Preguntas frecuentes sobre pilas {def.name}</h2>
      {def.faqs.map((faq, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-question">¿{faq.question}?</summary>
          <div class="faq-answer"><p>{faq.answer}</p></div>
        </details>
      ))}
    </section>
  </div>
</Base>

<style>
.brand-intro{background:#f8faff;border-left:4px solid #f49600;border-radius:0 8px 8px 0;padding:1rem 1.25rem;margin:1.5rem 0 2rem;color:#333;line-height:1.8}
.brand-table-section{margin:2rem 0 3rem}
.brand-table-section h2{font-size:1.3rem;font-weight:700;margin-bottom:1rem}
.table-wrapper{overflow-x:auto;border-radius:10px;border:1px solid #e0e8f0}
.brand-table{width:100%;border-collapse:collapse;font-size:.9rem}
.brand-table th{background:#f0f4ff;color:#1a1a2e;font-weight:700;padding:.7rem 1rem;text-align:left;white-space:nowrap}
.brand-table td{padding:.65rem 1rem;border-bottom:1px solid #f0f4ff;color:#333}
.brand-table tr:last-child td{border-bottom:none}
.brand-table tr:hover td{background:#fafcff}
.pill-link{background:#0066cc;color:#fff!important;padding:.2rem .55rem;border-radius:4px;font-size:.8rem;font-weight:700;font-family:monospace;letter-spacing:.03em;transition:background .15s}
.pill-link:hover{background:#0055b3;text-decoration:none!important}
</style>
