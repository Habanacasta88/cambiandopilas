---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { generateExcerpt, cleanWpContent } from '../../utils/content';
import postsData from '../../data/posts.json';

const POSTS_PER_PAGE = 24;
const totalPages = Math.ceil(postsData.length / POSTS_PER_PAGE);

export function getStaticPaths() {
  const perPage = 24;
  const total = Math.ceil(postsData.length / perPage);
  const paths = [];

  // /blog (page 1)
  paths.push({
    params: { page: undefined },
    props: { currentPage: 1, totalPages: total },
  });

  // /blog/2, /blog/3, etc.
  for (let i = 2; i <= total; i++) {
    paths.push({
      params: { page: String(i) },
      props: { currentPage: i, totalPages: total },
    });
  }

  return paths;
}

const { currentPage, totalPages: tp } = Astro.props;
const start = (currentPage - 1) * POSTS_PER_PAGE;
const paginatedPosts = postsData.slice(start, start + POSTS_PER_PAGE);
---

<Base
  title={`Blog${currentPage > 1 ? ` - Página ${currentPage}` : ''} - Cambiando de Pilas`}
  description="Todos los artículos sobre cómo cambiar pilas y baterías de llaves de coche, auriculares, relojes y dispositivos electrónicos."
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Blog', url: '/blog' }]} />

    <header class="article-header">
      <h1>Todos los artículos</h1>
      <p style="color:#666">{postsData.length} guías sobre cambio de pilas y baterías</p>
    </header>

    <div class="card-grid">
      {paginatedPosts.map((post: any) => (
        <ArticleCard
          title={post.title}
          slug={post.slug}
          excerpt={post.seoDescription || post.excerpt || generateExcerpt(cleanWpContent(post.body || ''), 120)}
          featuredImage={post.featuredImage}
          date={post.date}
        />
      ))}
    </div>

    {tp > 1 && (
      <nav class="pagination" aria-label="Paginación">
        {currentPage > 1 && (
          <a href={currentPage === 2 ? '/blog' : `/blog/${currentPage - 1}`} class="pagination-btn">&laquo; Anterior</a>
        )}
        <span class="pagination-info">Página {currentPage} de {tp}</span>
        {currentPage < tp && (
          <a href={`/blog/${currentPage + 1}`} class="pagination-btn">Siguiente &raquo;</a>
        )}
      </nav>
    )}
  </div>
</Base>
